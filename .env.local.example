# Backend URL for the Next.js client.
# Local dev: point at the FastAPI dev server.
# Production on Vercel: leave EMPTY (or unset) so requests stay same-origin (/api/*).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

NEXT_PUBLIC_COMPANY_NAME=شركة الأمل للتجارة
NEXT_PUBLIC_USER_NAME=عمر عبدالله
NEXT_PUBLIC_USER_ROLE=مدير التحصيل
