# Copy this file to .env and fill in your real values.
# IMPORTANT: never commit the real .env (it is git-ignored).

# Supabase — service_role key, server-side only
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your_service_role_key_here

# Gemini — used for both OCR and the LangGraph agent (ChatGoogleGenerativeAI)
GEMINI_API_KEY=your_gemini_api_key_here

# Resend — for sending reminder emails from the agent
# Without RESEND_API_KEY the agent falls back to a "simulation" mode that logs
# to agent_actions as `reminder_simulated` instead of sending real email.
RESEND_API_KEY=re_your_resend_api_key_here

# Must match a verified sender/domain in your Resend account.
# For quick tests you can use the Resend onboarding sender (onboarding@resend.dev).
FROM_EMAIL=collections@yourcompany.com

# Company name shown in the dashboard
COMPANY_NAME=شركة الأمل للتجارة
